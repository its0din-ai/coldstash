# Copy this to .env and fill in real values

# REQUIRED in production — min 32 random characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-MIN-32-CHARS

# Change this to yourdomain on production
NEXT_PUBLIC_BASE_URL=https://localhost/

# Optional overrides
# DB_PATH=./coldstash.db
# LOG_DIR=./logging
# NODE_ENV=production
# ADMIN_PASSWORD=SECURE-ADMIN-PASSWORD
